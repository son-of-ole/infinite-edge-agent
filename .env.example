# Browser app
VITE_DEFAULT_MODEL=Qwen/Qwen3-0.6B
VITE_LLM_BACKEND=unlocked-browser-transformer
VITE_COMPILED_WEBLLM_ENABLED=false
VITE_REQUIRE_UNLOCKED_RUNTIME=true
VITE_REQUIRE_WEBGPU_KERNELS=true
VITE_UNLOCKED_MODEL_MANIFEST_PATH=/models/qwen3-0.6b-unlocked/manifest.json
VITE_UNLOCKED_MODEL_MANIFEST_SHA256=6f89087e755568187951956a39077a3d9e5538768399e982febf76364e4caebd
VITE_UNLOCKED_MANIFEST_FORMAT=sharded
VITE_UNLOCKED_WEIGHT_FORMAT=f16-packed
# Fixture weights are an explicit CI/proof preset only. Keep false for live Qwen runs.
VITE_UNLOCKED_ALLOW_FIXTURE=false
VITE_UNLOCKED_BACKEND_PREFERENCE=webgpu
# Runtime profiles: preview keeps local browser proof caps explicit, balanced raises them, ci is smallest,
# and full removes artificial prompt/layer/logit/generation caps unless an explicit override below is set.
VITE_UNLOCKED_RUNTIME_PROFILE=full
VITE_UNLOCKED_MAX_RUNTIME_PROMPT_TOKENS=
VITE_UNLOCKED_MAX_RUNTIME_LAYERS=
VITE_UNLOCKED_LOGIT_CANDIDATE_LIMIT=
VITE_UNLOCKED_MAX_GENERATION_TOKENS=
# Browser MTP is a lab-only draft/verify path. Keep production target-only unless
# a paired target-only comparison proves acceleration on the target device.
VITE_MTP_ENABLED=false
# `browser/qwen-prefix-drafter` is the preferred lab drafter; `browser/ngram-drafter`
# remains available as a deterministic fallback/proof source.
VITE_MTP_DRAFT_MODEL_ID=browser/qwen-prefix-drafter
VITE_MTP_NUM_SPECULATIVE_TOKENS=2
VITE_MTP_DRAFT_LAYER_COUNT=4
# Keep this at 0 for broad browser compatibility; strict release lanes can raise it with
# BROWSER_RUNTIME_BENCH_REQUIRE_MTP_ACCELERATION=true after device-specific speed proof.
VITE_MTP_MIN_ACCEPTANCE_RATE=0
VITE_MTP_DISABLE_WHEN_LATENCY_WORSE=true
# Browser-owned KV persistence is on for the unlocked runtime; OPFS is preferred with IndexedDB fallback.
VITE_KVSWAP_PERSISTENCE_ENABLED=true
VITE_KVSWAP_PERSISTENCE_PREFER_OPFS=true
VITE_KVSWAP_PERSISTENCE_MAX_BLOCKS=512
VITE_KVSWAP_PERSISTENCE_MAX_BYTES=268435456
VITE_KVSWAP_PERSISTENCE_CLEAR_ON_INIT=false
# App-level request budget sent with each chat turn. This is separate from runtime profile caps.
# Keep full layers for quality. Lower layers are faster but currently fail live Qwen output quality.
VITE_CHAT_MAX_RUNTIME_PROMPT_TOKENS=full
VITE_CHAT_MAX_RUNTIME_LAYERS=full
VITE_CHAT_LOGIT_CANDIDATE_LIMIT=full
VITE_CHAT_LOGIT_TOP_K=64
VITE_CHAT_LOGIT_TILE_ROWS=4096
VITE_CHAT_MAX_GENERATION_TOKENS=full
VITE_QWEN_THINKING_MODE=disabled
VITE_AGENT_MAX_PROMPT_TOKENS=40960
# Keep false for static app deploys. Host production shards from object storage/CDN unless this host is intentionally built to carry them.
VITE_BUNDLE_UNLOCKED_MODEL=false
# Local-only converter inputs. These are for scripts, not browser bundles.
UNLOCKED_CONVERT_INPUT_DIR=
UNLOCKED_CONVERT_OUTPUT_DIR=.artifacts/models/qwen3-0.6b-unlocked
UNLOCKED_CONVERT_MAX_LAYERS=
# Memory providers:
# - browser-vector: zero-config IndexedDB vector memory, deterministic local search, import/export, context-pack traces.
# - indexeddb: compatibility alias for older browser-only configs.
# - sidecar: optional local LanceDB sidecar at VITE_MEMORY_SERVER_URL.
# - remote-http: compatible HTTPS memory API that you operate or trust.
VITE_MEMORY_PROVIDER=browser-vector
# Fallback is enabled by default so sidecar/remote outages keep the browser-vector store usable.
# Set this to false only when an operator wants remote/sidecar startup to hard-fail.
VITE_ALLOW_MEMORY_FALLBACK=true
VITE_REMOTE_MEMORY_URL=
VITE_REMOTE_MEMORY_CREDENTIALS=same-origin
VITE_REMOTE_MEMORY_TENANT_ID=
VITE_REMOTE_MEMORY_CELL_ID=
VITE_ENABLE_MEMORY_SERVER=false
VITE_MEMORY_SERVER_URL=http://127.0.0.1:8787
VITE_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
VITE_EMBEDDING_PREFER_WEBGPU=false

# Optional LanceDB memory sidecar
MEMORY_SERVER_HOST=127.0.0.1
MEMORY_SERVER_PORT=8787
MEMORY_DB_URI=.data/lancedb
MEMORY_TABLE=memory_chunks
MEMORY_VECTOR_DIMENSION=384
MEMORY_API_PREFIX=/api/edge-ai
# Root /memory and /gac routes are exposed only on loopback by default. Set true only behind a trusted local/private wrapper.
MEMORY_EXPOSE_LOCAL_ROUTES=
MEMORY_SERVER_BODY_LIMIT_BYTES=2097152
MEMORY_SERVER_TOKEN=
MEMORY_TENANT_ID=
MEMORY_CELL_ID=
MEMORY_CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
# Optional hosted benchmark telemetry collector. Keep disabled unless users explicitly opt in from
# the browser benchmark URL with submitTelemetry=true or benchmarkTelemetry=true.
BENCHMARK_TELEMETRY_ENABLED=false
BENCHMARK_TELEMETRY_PREFIX=/api/benchmark-runs
BENCHMARK_TELEMETRY_STORAGE=jsonl
BENCHMARK_TELEMETRY_DIR=.data/benchmark-runs
BENCHMARK_TELEMETRY_DATABASE_URL=
BENCHMARK_TELEMETRY_MAX_ARTIFACT_BYTES=1048576
BENCHMARK_TELEMETRY_RATE_LIMIT_MAX=60
BENCHMARK_TELEMETRY_RATE_LIMIT_WINDOW_MS=600000
BENCHMARK_TELEMETRY_SUBMIT_TOKEN=
BENCHMARK_TELEMETRY_ADMIN_TOKEN=
HOSTED_PRODUCTION_BENCHMARK_URL=

# Local release/eval gates
EVAL_ARTIFACT_DIR=.artifacts/evals
RELEASE_REQUIRE_UNLOCKED_MODEL=false
RELEASE_REQUIRE_UNLOCKED_QWEN_MATH=false
RELEASE_REQUIRE_UNLOCKED_FULL_PROFILE=false
RELEASE_REQUIRE_UNLOCKED_STRICT_WEBGPU=true
RELEASE_REQUIRE_UNLOCKED_PACKED_ASSETS=true
RELEASE_REQUIRE_HOSTED_PROFILE=false
RELEASE_REQUIRE_BACKEND_READINESS_MATRIX=false
RELEASE_REQUIRE_SHARED_RUNTIME_READINESS=false
RELEASE_REQUIRE_V12_READINESS=false
# Open-source release gates are browser-first by default. Set true only for sidecar-packaged releases.
RELEASE_REQUIRE_SIDECAR=false
RELEASE_ALLOW_BUNDLED_UNLOCKED_MODEL=false
RELEASE_MAX_STATIC_FILE_BYTES=104857600
PRODUCTION_EVAL_SIDECAR_MODE=auto
PRODUCTION_EVAL_EXPECTED_DB_URI=.data/lancedb
PRODUCTION_EVAL_EXPECTED_TABLE_NAME=memory_chunks
PRODUCTION_EVAL_SIDECAR_START_COMMAND=
PRODUCTION_EVAL_SIDECAR_TIMEOUT_MS=12000

# Preset: browser-only local memory. No sidecar, hosted service, private endpoint, or external data store.
# VITE_MEMORY_PROVIDER=browser-vector
# VITE_ENABLE_MEMORY_SERVER=false
# VITE_REMOTE_MEMORY_URL=
#
# Preset: optional local LanceDB sidecar. Keep browser fallback enabled unless this profile should hard-fail.
# VITE_MEMORY_PROVIDER=sidecar
# VITE_ENABLE_MEMORY_SERVER=true
# VITE_MEMORY_SERVER_URL=http://127.0.0.1:8787
# MEMORY_DB_URI=.data/lancedb
#
# Preset: sidecar-packaged release gate. Use only when LanceDB is intentionally part of the release.
# RELEASE_REQUIRE_SIDECAR=true
# PRODUCTION_EVAL_SIDECAR_MODE=required
#
# Preset: remote memory endpoint. Bring your own endpoint and data store implementing docs/51_REMOTE_MEMORY_API_CONTRACT.md.
# VITE_MEMORY_PROVIDER=remote-http
# VITE_REMOTE_MEMORY_URL=https://your-memory.example.com/api/edge-ai
# VITE_REMOTE_MEMORY_CREDENTIALS=same-origin
# VITE_REMOTE_MEMORY_TENANT_ID=
# VITE_REMOTE_MEMORY_CELL_ID=
#
# Preset: compiled browser production candidate. Requires backend-specific Chrome proof before deploy-ready claims.
# VITE_LLM_BACKEND=compiled-browser-webllm
# VITE_DEFAULT_MODEL=Qwen3-0.6B-q4f16_1-MLC
# VITE_COMPILED_WEBLLM_ENABLED=true
# VITE_REQUIRE_UNLOCKED_RUNTIME=false
# VITE_REQUIRE_WEBGPU_KERNELS=false
# VITE_MTP_ENABLED=false
#
# Preset: opt-in hosted benchmark telemetry. Requires a server endpoint, and each benchmark URL
# must also pass submitTelemetry=true or benchmarkTelemetry=true. Hosted production telemetry
# should use postgres, not jsonl.
# VITE_BENCHMARK_TELEMETRY_ENABLED=true
# VITE_BENCHMARK_TELEMETRY_URL=/api/benchmark-runs
# BENCHMARK_TELEMETRY_ENABLED=true
# BENCHMARK_TELEMETRY_PREFIX=/api/benchmark-runs
# BENCHMARK_TELEMETRY_STORAGE=postgres
# BENCHMARK_TELEMETRY_DATABASE_URL=<postgres-connection-string>
# BENCHMARK_TELEMETRY_DIR=.data/benchmark-runs
# BENCHMARK_TELEMETRY_RATE_LIMIT_MAX=60
# BENCHMARK_TELEMETRY_RATE_LIMIT_WINDOW_MS=600000
# BENCHMARK_TELEMETRY_ADMIN_TOKEN=<dashboard-export-token>
# VITE_APP_VERSION=0.1.0
# VITE_GIT_SHA=<deployment-sha>
# VITE_DEPLOY_URL=https://your-hosted-agent.example
# HOSTED_PRODUCTION_BENCHMARK_URL=https://your-hosted-agent.example/__bench/browser-runtime?backend=compiled-browser-webllm&modelId=Qwen3-0.6B-q4f16_1-MLC&memoryGrounding=montana_capital&expectedExact=Helena&submitTelemetry=true&qwenThinkingMode=disabled
# Run `pnpm verify:hosted-profile` before claiming hosted production readiness.
#
# Preset: unlocked preview fixture. Use for CI and local runtime-control proofs without shipping model weights.
# VITE_LLM_BACKEND=unlocked-browser-transformer
# VITE_DEFAULT_MODEL=Qwen/Qwen3-0.6B
# VITE_REQUIRE_UNLOCKED_RUNTIME=true
# VITE_UNLOCKED_ALLOW_FIXTURE=true
# VITE_UNLOCKED_RUNTIME_PROFILE=preview
# VITE_UNLOCKED_BACKEND_PREFERENCE=webgpu
# RELEASE_REQUIRE_UNLOCKED_MODEL=false
# RELEASE_REQUIRE_SIDECAR=false
#
# Preset: unlocked full model-backed release. Requires BYO licensed converted weights hosted outside git.
# VITE_LLM_BACKEND=unlocked-browser-transformer
# VITE_DEFAULT_MODEL=Qwen/Qwen3-0.6B
# VITE_REQUIRE_UNLOCKED_RUNTIME=true
# VITE_UNLOCKED_MODEL_MANIFEST_PATH=/models/qwen3-0.6b-unlocked/manifest.json
# VITE_UNLOCKED_MODEL_MANIFEST_SHA256=<64-character-sha256-hex-digest>
# VITE_UNLOCKED_MANIFEST_FORMAT=sharded
# VITE_UNLOCKED_WEIGHT_FORMAT=f16-packed
# VITE_UNLOCKED_ALLOW_FIXTURE=false
# VITE_UNLOCKED_RUNTIME_PROFILE=full
# VITE_UNLOCKED_BACKEND_PREFERENCE=webgpu
# RELEASE_REQUIRE_UNLOCKED_MODEL=true
# RELEASE_REQUIRE_UNLOCKED_QWEN_MATH=true
# RELEASE_REQUIRE_UNLOCKED_FULL_PROFILE=true
# RELEASE_REQUIRE_UNLOCKED_PACKED_ASSETS=true
